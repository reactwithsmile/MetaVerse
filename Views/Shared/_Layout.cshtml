<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MetaSphere Leads</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/metasphere.css" asp-append-version="true" />

    <style>
        #msChatbotWrapper {
            position: fixed;
            right: 20px;
            bottom: 24px;
            z-index: 1050;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }
        .ms-chatbot-label {
            background: rgba(6,11,30,0.85);
            color: #cfe8ff;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            box-shadow: 0 6px 18px rgba(11,7,23,0.45);
            border: 1px solid rgba(255,255,255,0.04);
            white-space: nowrap;
        }
        .ms-chatbot-button {
            /* removed fixed positioning so it's placed by wrapper */
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg,#8b5cf6,#06b6d4);
            color: #fff;
            display:flex;
            align-items:center;
            justify-content:center;
            box-shadow: 0 8px 24px rgba(11,7,23,0.5);
            border: none;
            cursor: pointer;
        }
        .ms-chatbot-panel {
            position: fixed;
            right: 20px;
            bottom: 92px;
            z-index: 1050;
            width: 320px;
            max-width: calc(100% - 48px);
            background: linear-gradient(180deg, rgba(12,11,20,0.96), rgba(18,17,28,0.96));
            color: #e6e6f0;
            border-radius: 12px;
            box-shadow: 0 12px 40px rgba(11,7,23,0.6);
            overflow: hidden;
            display: none;
            flex-direction: column;
            font-family: Rajdhani, sans-serif;
        }
        .ms-chatbot-header {
            padding: 12px 14px;
            display:flex;
            align-items:center;
            justify-content:space-between;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .ms-chatbot-messages {
            padding: 12px;
            max-height: 260px;
            overflow-y: auto;
        }
        .ms-chatbot-option {
            background: rgba(255,255,255,0.03);
            margin: 8px 0;
            padding: 10px 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: background .12s;
            color: #cfd6ff;
        }
        .ms-chatbot-option:hover { background: rgba(255,255,255,0.06); }
        .ms-chatbot-user { text-align:right; color:#bfe3ff; font-size:13px; margin:6px 0; }
        .ms-chatbot-bot { text-align:left; color:#d6d6ff; font-size:13px; margin:6px 0; }
        .ms-chatbot-footer {
            padding: 10px;
            border-top: 1px solid rgba(255,255,255,0.04);
            display:flex;
            gap:8px;
            align-items:center;
        }
        .ms-chatbot-typing { font-size: 13px; color: #9aa4ff; }
        .ms-chatbot-close { background: transparent; border: none; color: #e6e6f0; cursor: pointer; }
    </style>
</head>
<body>
    <!-- Animated background particles -->
    <div class="bg-particles" id="particles"></div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top ms-navbar">
        <div class="container">
            <a class="navbar-brand ms-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">⬡</span> MetaSphere
            </a>
            <button class="navbar-toggler ms-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto me-auto">
                    <li class="nav-item"><a class="nav-link ms-nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link ms-nav-link" asp-controller="Explore" asp-action="Index">Explore</a></li>
                    <li class="nav-item"><a class="nav-link ms-nav-link" asp-controller="About" asp-action="Index">Roadmap</a></li>
                    <li class="nav-item"><a class="nav-link ms-nav-link" asp-controller="Contact" asp-action="Index">Contact</a></li>
                    <li class="nav-item"><a class="nav-link ms-nav-link" asp-controller="Admin" asp-action="Index">Admin</a></li>
                </ul>
                <button class="btn btn-wallet" onclick="alert('Web3 wallet integration coming soon!')">
                    <i class="fas fa-wallet me-1"></i> Connect Wallet
                </button>
            </div>
        </div>
    </nav>

    <!-- Main content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="ms-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-md-4">
                    <div class="ms-brand fs-4 mb-2"><span class="brand-icon">⬡</span> MetaSphere</div>
                    <p class="text-muted small">The next frontier of digital ownership and virtual experiences.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-neon mb-3">Quick Links</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-controller="Explore" asp-action="Index">Explore Assets</a></li>
                        <li><a asp-controller="About" asp-action="Index">Roadmap</a></li>
                        <li><a asp-controller="Contact" asp-action="Index">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-neon mb-3">Connect</h6>
                    <div class="social-icons">
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-discord"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-telegram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-purple mt-4" />
            <p class="text-center text-muted small mb-0">&copy; @DateTime.Now.Year MetaSphere Leads. All rights reserved.</p>
        </div>
    </footer>

    <!-- Success Modal -->
    @if (TempData["Success"] != null)
    {
        <div class="ms-modal-overlay" id="successModal">
            <div class="ms-modal glass-card">
                <div class="modal-glow"></div>
                <div class="text-center p-4">
                    <div class="success-icon mb-3"><i class="fas fa-check-circle"></i></div>
                    <h4 class="text-neon">Success!</h4>
                    <p class="text-light">@TempData["Success"]</p>
                    <button class="btn btn-neon mt-2" onclick="document.getElementById('successModal').style.display='none'">
                        Close
                    </button>
                </div>
            </div>
        </div>
    }

    <div id="msChatbotWrapper">
        <div class="ms-chatbot-label" id="msChatbotLabel">Chat with assistant</div>
        <button id="msChatbotButton" class="ms-chatbot-button" aria-label="Open chat">
            <i class="fas fa-comment-alt"></i>
        </button>
    </div>

    <div id="msChatbotPanel" class="ms-chatbot-panel" role="dialog" aria-label="Chatbot">
        <div class="ms-chatbot-header">
            <div>
                <strong>Assistant</strong>
                <div style="font-size:12px;color:#9aa4ff">Write a queries</div>
            </div>
            <div>
                <button id="msChatbotClose" class="ms-chatbot-close" title="Close"><i class="fas fa-times"></i></button>
            </div>
        </div>
        <div class="ms-chatbot-messages" id="msChatbotMessages">
        </div>
        <div class="ms-chatbot-footer" id="msChatbotFooter">
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/metasphere.js" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
