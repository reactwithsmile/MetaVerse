@model IEnumerable<MetaSphere.Models.Lead>
@{ ViewData["Title"] = "Leads"; }

<section class="section-pad">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 reveal">
            <div>
                <h2 class="text-gradient mb-0" style="font-family:'Orbitron',monospace">Leads</h2>
                <small class="text-muted">@Model.Count() total inquiries</small>
            </div>
            <a asp-action="Index" class="btn btn-neon btn-neon-blue" style="font-size:.65rem"><span>← Dashboard</span></a>
        </div>

        <div class="glass-card reveal" style="overflow:hidden">
            <table class="ms-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Item</th>
                        <th>Message</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in Model)
                    {
                        <tr>
                            <td style="font-weight:600">@lead.Name</td>
                            <td style="color:var(--neon-blue)">@lead.Email</td>
                            <td style="color:var(--text-muted)">@(lead.Phone ?? "—")</td>
                            <td>
                                @if (lead.Item != null)
                                {
                                    <span class="nft-tag position-static" style="font-size:.6rem">@lead.Item.Title</span>
                                }
                                else
                                {
                                    <span style="color:#555">General</span>
                                }
                            </td>
                            <td style="color:var(--text-muted);font-size:.85rem;max-width:200px">
                                <span title="@lead.Message">@(lead.Message.Length > 60 ? lead.Message[..60] + "…" : lead.Message)</span>
                            </td>
                            <td style="color:var(--text-muted);font-size:.8rem">@lead.SubmittedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <form asp-action="DeleteLead" method="post" onsubmit="return confirm('Delete this lead?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@lead.Id" />
                                    <button type="submit" class="btn btn-neon btn-neon-pink" style="font-size:.6rem;padding:.3rem .8rem"><span>Delete</span></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4" style="color:var(--text-muted)">No leads yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
